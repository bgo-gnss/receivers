          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (sid)\n  sid as \"Station\",\n  recv_volt as \"Voltage\",\n  overall_status as \"Status\",\n  timestamp as \"Last Update\",\n  (SELECT MIN(recv_volt) FROM checkcomm c2 WHERE c2.sid = c1.sid AND $__timeFilter(c2.timestamp)) as \"Min Voltage\",\n  (SELECT MAX(recv_volt) FROM checkcomm c2 WHERE c2.sid = c1.sid AND $__timeFilter(c2.timestamp)) as \"Max Voltage\"\nFROM checkcomm c1\nWHERE $__timeFilter(timestamp)\n  AND overall_status IN ('critical', 'warning')\nORDER BY sid, timestamp DESC",
          "refId": "A"
        }
      ],
