      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gps_health"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  d.station_id AS \"Station\",\n  d.receiver_type AS \"Receiver\",\n  d.antenna_type AS \"Antenna\",\n  d.seconds_since_update AS \"Checked\",\n  CASE\n    WHEN d.is_online IS NULL THEN NULL\n    WHEN d.is_online THEN 'online ' || format_duration(d.state_duration)\n    ELSE 'offline ' || format_duration(d.state_duration)\n  END AS \"Conn\",\n  CASE\n    WHEN d.download_status IS NULL THEN NULL\n    WHEN d.download_status = 'open' AND (d.port_health_status = 'open' OR d.port_health_status IS NULL) THEN 'active'\n    WHEN d.download_status IN ('refused', 'timeout', 'error') THEN 'dl:' || d.download_status\n    WHEN d.port_health_status IN ('refused', 'timeout', 'error') THEN 'hc:' || d.port_health_status\n    ELSE 'unknown'\n  END AS \"Port\",\n  CASE\n    WHEN d.is_online = false THEN 'offline'\n    WHEN d.download_status = 'refused' OR d.port_health_status = 'refused' THEN 'port forward missing'\n    WHEN d.download_status = 'timeout' AND (d.port_health_status = 'timeout' OR d.port_health_status IS NULL) THEN 'offline'\n    WHEN d.overall_status = 'critical' THEN 'CRITICAL: ' || COALESCE(d.status_details, '')\n    WHEN d.overall_status = 'warning' THEN 'WARNING: ' || COALESCE(d.status_details, '')\n    WHEN d.overall_status = 'healthy' THEN 'OK'\n    ELSE COALESCE(d.overall_status, 'unknown')\n  END AS \"Status\",\n  d.voltage AS \"Voltage\",\n  d.satellites_tracked AS \"Sats\",\n  d.ntrip_status AS \"NTRIP\",\n  d.uptime_seconds AS \"Uptime\"\nFROM station_dashboard_data d\nWHERE ('$area' = 'all' OR EXISTS (SELECT 1 FROM station_area_members sam WHERE sam.sid = d.station_id AND sam.area_id = '$area'))\n  AND (${station:singlequote} = 'all' OR d.station_id = ${station:singlequote})\n  AND (${receiver:singlequote} = 'all' OR d.receiver_type = ${receiver:singlequote})\n  AND (${antenna:singlequote} = 'all' OR d.antenna_type = ${antenna:singlequote})\nORDER BY d.station_id",
          "refId": "A"
        }
      ],
      "title": "All Stations - $area",
      "type": "table"
    },
