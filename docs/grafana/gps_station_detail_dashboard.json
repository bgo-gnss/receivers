            "type": "grafana-postgresql-datasource",
            "uid": "gps_health"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE overall_status\n  WHEN 'healthy' THEN 0\n  WHEN 'warning' THEN 1\n  WHEN 'critical' THEN 2\n  ELSE 3\nEND AS \"Status\",\nCASE WHEN status_details IS NOT NULL\n  THEN status_details\n  ELSE ''\nEND AS \"Details\"\nFROM block_health_summary\nWHERE sid = '$station'\nORDER BY ts DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "title": "Overall Status",
      "description": "Details field shows what is causing non-healthy status (e.g. 'Voltage, FTP down')",
      "type": "stat"
