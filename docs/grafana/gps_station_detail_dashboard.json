      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gps_health"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  CASE \n    WHEN s.ip_address IS NOT NULL THEN host(s.ip_address) || ':' || COALESCE(s.http_port, 80)::text\n    ELSE ''\n  END AS url,\n  CASE \n    WHEN s.ip_address IS NOT NULL THEN host(s.ip_address) || ':' || COALESCE(s.http_port, 80)::text || ' (' || COALESCE(s.receiver_type, '?') || ')'\n    ELSE COALESCE(s.receiver_type, 'Unknown')\n  END AS \"Receiver\",\n  CASE \n    WHEN s.latitude IS NOT NULL THEN \n      ROUND(s.latitude::numeric, 4)::text || ', ' || ROUND(s.longitude::numeric, 4)::text\n    ELSE 'No coordinates'\n  END AS \"Location\"\nFROM stations s\nWHERE s.sid = '$station'",
          "refId": "A"
        }
      ],
      "title": "Station Information",
      "type": "table"
    },
