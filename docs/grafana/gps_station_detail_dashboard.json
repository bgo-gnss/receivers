          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.ts AS \"Time\",\n  p.voltage AS \"Voltage\",\n  r.temperature AS \"Temperature\",\n  r.cpu_load AS \"CPU\",\n  d.usage_percent AS \"Disk\",\n  sat.total AS \"Satellites\",\n  hs.overall_status AS \"Status\"\nFROM block_power_status p\nLEFT JOIN block_receiver_status r ON p.sid = r.sid AND p.ts = r.ts\nLEFT JOIN block_disk_status d ON p.sid = d.sid AND p.ts = d.ts\nLEFT JOIN block_satellite_tracking sat ON p.sid = sat.sid AND p.ts = sat.ts\nLEFT JOIN block_health_summary hs ON p.sid = hs.sid AND p.ts = hs.ts\nWHERE p.sid = '$station'\n  AND $__timeFilter(p.ts)\nORDER BY p.ts DESC\nLIMIT 100",
