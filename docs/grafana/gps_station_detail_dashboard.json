          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  (SELECT CASE\n    WHEN NOT EXISTS (SELECT 1 FROM file_tracking WHERE sid='$station' AND session_type='15s_24hr' AND status='downloaded') THEN -1\n    ELSE (SELECT ROUND(EXTRACT(EPOCH FROM NOW() - (file_date + INTERVAL '1 day')))\n          FROM file_tracking WHERE sid='$station' AND session_type='15s_24hr'\n          AND status='downloaded' ORDER BY file_date DESC LIMIT 1)\n  END) AS \"24h\",\n  (SELECT CASE\n    WHEN NOT EXISTS (SELECT 1 FROM file_tracking WHERE sid='$station' AND session_type='1Hz_1hr' AND status='downloaded') THEN -1\n    ELSE (SELECT ROUND(EXTRACT(EPOCH FROM NOW() - (file_date + file_hour * INTERVAL '1 hour')))\n          FROM file_tracking WHERE sid='$station' AND session_type='1Hz_1hr'\n          AND status='downloaded' ORDER BY file_date DESC, file_hour DESC NULLS LAST LIMIT 1)\n  END) AS \"1Hz\",\n  (SELECT CASE\n    WHEN NOT EXISTS (SELECT 1 FROM file_tracking WHERE sid='$station' AND session_type='status_1hr' AND status='downloaded') THEN -1\n    ELSE (SELECT ROUND(EXTRACT(EPOCH FROM NOW() - (file_date + file_hour * INTERVAL '1 hour')))\n          FROM file_tracking WHERE sid='$station' AND session_type='status_1hr'\n          AND status='downloaded' ORDER BY file_date DESC, file_hour DESC NULLS LAST LIMIT 1)\n  END) AS \"Status\"",
          "refId": "A"
        }
      ],
      "title": "File Status",
      "type": "stat"
    },
