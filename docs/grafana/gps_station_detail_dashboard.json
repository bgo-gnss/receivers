          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT extract(epoch from now() - max(latest_ts))::integer AS \"Age\"\nFROM (\n  SELECT max(ts) AS latest_ts FROM block_health_summary WHERE sid = '$station'\n  UNION ALL\n  SELECT max(ts) FROM block_power_status WHERE sid = '$station'\n  UNION ALL\n  SELECT max(ts) FROM block_receiver_status WHERE sid = '$station'\n  UNION ALL\n  SELECT max(ts) FROM block_pvt_geodetic WHERE sid = '$station'\n) t",
          "refId": "A"
        }
      ],
      "title": "Last Observation",
      "type": "stat"
    },
