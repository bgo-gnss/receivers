          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Online\",\n  CASE\n    WHEN '$status_filter' = 'online' THEN 'not_online'\n    WHEN '$status_filter' = 'not_online' THEN 'all'\n    ELSE 'online'\n  END AS \"next_filter\"\nFROM station_connectivity sc\nJOIN stations s ON s.sid = sc.sid\nWHERE sc.is_online = true\n  AND s.station_status IS DISTINCT FROM 'discontinued'",
