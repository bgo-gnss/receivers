      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "gps_health"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  d.station_id AS sid,\n  d.latitude,\n  d.longitude,\n  CASE\n    WHEN d.station_status IS NOT NULL THEN -1\n    WHEN d.health_check = 'passive' THEN -1\n    WHEN f.disk_status = 2 THEN 1\n    WHEN d.overall_status = 'healthy' AND COALESCE(f.download_status, 0) >= 2 THEN 2\n    WHEN d.overall_status = 'healthy' THEN 3\n    WHEN d.overall_status = 'warning' THEN 2\n    WHEN d.overall_status = 'critical' THEN 1\n    ELSE 0\n  END AS status_code,\n  CASE\n    WHEN d.station_status IS NOT NULL THEN -1\n    WHEN d.health_check = 'passive' THEN -1\n    WHEN f.status_24h = 0 THEN 3\n    WHEN f.status_24h = 1 THEN 2\n    WHEN f.status_24h = 2 THEN 0\n    ELSE 0\n  END AS data_status_code,\n  d.receiver_type AS \"Receiver\",\n  COALESCE(d.overall_status, 'unknown') AS \"Health\",\n  CASE\n    WHEN d.station_status IS NOT NULL THEN d.station_status\n    WHEN d.health_check = 'passive' THEN 'passive'\n    WHEN d.connection_state IS NULL THEN 'unknown'\n    WHEN d.connection_state = 'online' THEN 'online ' || format_duration(d.state_duration)\n    WHEN d.connection_state = 'degraded' THEN 'degraded ' || format_duration(d.state_duration)\n    ELSE 'offline ' || format_duration(d.state_duration)\n  END AS \"Connection\",\n  CASE WHEN d.station_status IS NOT NULL OR d.health_check = 'passive' THEN '-' WHEN d.voltage IS NOT NULL THEN ROUND(d.voltage::numeric, 1) || ' V' ELSE '-' END AS \"Voltage\",\n  CASE WHEN d.station_status IS NOT NULL OR d.health_check = 'passive' THEN '-' WHEN d.temperature IS NOT NULL THEN d.temperature || ' C' ELSE '-' END AS \"Temp\",\n  CASE WHEN d.station_status IS NOT NULL OR d.health_check = 'passive' THEN '-' ELSE COALESCE(d.satellites_tracked::text, '-') END AS \"Sats\",\n  CASE WHEN d.station_status IS NOT NULL OR d.health_check = 'passive' THEN '-' WHEN d.disk_usage_pct IS NOT NULL THEN ROUND(d.disk_usage_pct::numeric, 0) || '%' ELSE '-' END AS \"Disk\",\n  CASE WHEN d.station_status IS NOT NULL THEN d.station_status WHEN d.health_check = 'passive' THEN '-' ELSE COALESCE(d.ntrip_status, '-') END AS \"NTRIP\",\n  COALESCE(d.status_details, '') AS \"Details\"\nFROM station_dashboard_data d\nLEFT JOIN station_data_flow_status f ON f.sid = d.station_id\nLEFT JOIN stations s ON s.sid = d.station_id\nWHERE d.latitude IS NOT NULL\n  AND d.longitude IS NOT NULL\n  AND ('$area' = 'all' OR EXISTS (SELECT 1 FROM station_area_members sam WHERE sam.sid = d.station_id AND sam.area_id = '$area'))\n  AND (${station:singlequote} = 'all' OR d.station_id = ${station:singlequote})\n  AND (${receiver:singlequote} = 'all' OR (${receiver:singlequote} = 'NONE' AND d.receiver_type IS NULL) OR d.receiver_type = ${receiver:singlequote})\n  AND (${antenna:singlequote} = 'all' OR (${antenna:singlequote} = 'NONE' AND d.antenna_type IS NULL) OR d.antenna_type = ${antenna:singlequote})\n  AND (${owner:singlequote} = 'all' OR s.station_owner = ${owner:singlequote})\n  AND ('$status_filter' = 'all'\n    OR ('$status_filter' = 'online' AND d.is_online = true AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'offline' AND d.is_online = false AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'critical' AND d.overall_status = 'critical' AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'warning' AND d.overall_status = 'warning' AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'ping_failed' AND d.status_details LIKE '%Ping%' AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'ftp_down' AND d.ftp_open = false AND d.is_online = true AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'ctrl_refused' AND d.control_open = false AND d.is_online = true AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'disk_warning' AND d.status_details LIKE '%Disk%' AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'discontinued' AND d.station_status = 'discontinued')\n    OR ('$status_filter' = 'passive' AND d.health_check = 'passive')\n    OR ('$status_filter' = 'inactive' AND d.station_status = 'inactive')\n    OR ('$status_filter' = '24hr_rinex_missing' AND f.status_24h = 2 AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = '1hr_rinex_missing' AND f.status_1hz = 2 AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'voltage_warning' AND d.voltage IS NOT NULL AND (d.status_details LIKE '%Voltage%' OR (d.is_online = false AND ((COALESCE(s.power_type, 'battery') = 'battery' AND (d.voltage < 11.8 OR d.voltage > 15.0)) OR (s.power_type = 'dcdc' AND (d.voltage < 12.0 OR d.voltage > 16.5)) OR (s.power_type = 'mains' AND (d.voltage < 15.0 OR d.voltage > 25.0))))))\n    OR ('$status_filter' = 'download_warning' AND f.download_status >= 1 AND d.station_status IS NULL AND d.health_check IS NULL)\n    OR ('$status_filter' = 'disk_error' AND f.disk_status = 2 AND d.station_status IS NULL AND d.health_check IS NULL)\n  )\nORDER BY d.station_id",
          "refId": "A"
        }
      ],
      "title": "GPS Station Map - $area",
      "type": "geomap"
    }
  ],
