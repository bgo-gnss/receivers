          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Volt Warn\",\n  CASE\n    WHEN '$status_filter' = 'voltage_warning' THEN 'not_voltage_warning'\n    WHEN '$status_filter' = 'not_voltage_warning' THEN 'all'\n    ELSE 'voltage_warning'\n  END AS \"next_filter\" FROM station_dashboard_data d JOIN stations s ON s.sid = d.station_id WHERE d.station_status IS NULL AND d.health_check IS NULL AND d.voltage IS NOT NULL AND (d.status_details LIKE '%Voltage%' OR (d.is_online = false AND ((COALESCE(s.power_type, 'battery') = 'battery' AND (d.voltage < 11.8 OR d.voltage > 15.0)) OR (s.power_type = 'dcdc' AND (d.voltage < 12.0 OR d.voltage > 16.5)) OR (s.power_type = 'mains' AND (d.voltage < 15.0 OR d.voltage > 25.0)))))",
          "refId": "A"
        }
      ],
      "title": "Volt Warn",
      "type": "stat"
