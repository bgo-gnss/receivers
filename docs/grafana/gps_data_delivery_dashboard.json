      "pluginVersion": "10.0.0",
      "targets": [{
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "gps_health"},
        "editorMode": "code", "format": "time_series", "rawQuery": true,
        "rawSql": "WITH active AS (\n  SELECT COUNT(*)::float AS n\n  FROM stations\n  WHERE station_status IS NULL AND health_check IS NULL\n), days AS (\n  SELECT generate_series(\n    GREATEST(($__timeFrom())::date, CURRENT_DATE - 30),\n    LEAST(($__timeTo())::date, CURRENT_DATE),\n    '1 day'::interval\n  )::date AS d\n)\nSELECT\n  days.d AS time,\n  100.0 * COUNT(DISTINCT ft.sid) FILTER (\n    WHERE ft.session_type = '15s_24hr'\n      AND ft.status IN ('downloaded', 'archived')\n  ) / NULLIF((SELECT n FROM active), 0) AS \"24h raw\",\n  100.0 * COUNT(DISTINCT ft.sid) FILTER (\n    WHERE ft.session_type = '15s_24hr_rinex'\n      AND ft.status IN ('downloaded', 'archived')\n  ) / NULLIF((SELECT n FROM active), 0) AS \"24h RINEX\"\nFROM days\nLEFT JOIN file_tracking ft ON ft.file_date = days.d\nGROUP BY days.d\nORDER BY days.d",
        "refId": "A"
      }],
      "title": "Daily completeness · % of active stations delivering per day",
      "type": "timeseries"
    },
