        "rawSql": "WITH areas AS (\n  SELECT sam.sid, string_agg(sa.area_name, ', ' ORDER BY sa.area_name) AS area_list\n  FROM station_area_members sam\n  JOIN station_areas sa ON sa.area_id = sam.area_id\n  GROUP BY sam.sid\n)\nSELECT\n  d.station_id AS \"SID\",\n  d.receiver_type AS \"Receiver\",\n  a.area_list AS \"Area\",\n  f.status_24h AS \"24hR\",\n  f.raw_24h_date::text AS \"24h Date\",\n  f.rinex_24h_status AS \"RNX\",\n  f.download_status AS \"DL\",\n  d.last_download_at AS \"Last DL\",\n  ROUND(d.avg_speed_bps / 1024.0, 1) AS \"KB/s\",\n  d.stalls AS \"Stalls\",\n  d.download_failures AS \"Fails\"\nFROM station_dashboard_data d\nLEFT JOIN station_data_flow_status f ON f.sid = d.station_id\nLEFT JOIN areas a ON a.sid = d.station_id\nLEFT JOIN stations s ON s.sid = d.station_id\nWHERE ('$area' = 'all' OR EXISTS (SELECT 1 FROM station_area_members sam WHERE sam.sid = d.station_id AND sam.area_id = '$area'))\n  AND (${station:singlequote} = 'all' OR d.station_id = ${station:singlequote})\n  AND (${receiver:singlequote} = 'all' OR (${receiver:singlequote} = 'NONE' AND d.receiver_type IS NULL) OR d.receiver_type = ${receiver:singlequote})\n  AND (${antenna:singlequote} = 'all' OR (${antenna:singlequote} = 'NONE' AND d.antenna_type IS NULL) OR d.antenna_type = ${antenna:singlequote})\n  AND (${owner:singlequote} = 'all' OR s.station_owner = ${owner:singlequote})\n  AND ('$data_filter' = 'all'\n    OR ('$data_filter' = '24h_raw_ok'      AND f.status_24h = 0)\n    OR ('$data_filter' = '24h_raw_late'    AND f.status_24h = 1)\n    OR ('$data_filter' = '24h_raw_missing' AND f.status_24h = 2)\n    OR ('$data_filter' = '24h_rnx_ok'      AND f.rinex_24h_status = 0)\n    OR ('$data_filter' = '24h_rnx_missing' AND f.rinex_24h_status >= 1)\n    OR ('$data_filter' = 'rnx_gap'         AND f.status_24h = 0 AND f.rinex_24h_status >= 1)\n    OR ('$data_filter' = 'dl_warning'      AND f.download_status = 1)\n    OR ('$data_filter' = 'dl_critical'     AND f.download_status = 2)\n    OR ('$data_filter' = 'stalling'        AND d.stalls >= 1)\n    OR ('$data_filter' = 'slow_speed'      AND d.avg_speed_bps IS NOT NULL AND d.avg_speed_bps < 10240)\n    OR ('$data_filter' = 'passive'         AND d.health_check = 'passive')\n    OR ('$data_filter' = 'inactive'        AND d.station_status IS NOT NULL)\n  )\n  AND ('$data_filter' IN ('passive','inactive') OR (d.station_status IS NULL AND d.health_check IS NULL))\nORDER BY f.status_24h DESC NULLS LAST, f.rinex_24h_status DESC NULLS LAST, d.station_id",
        "refId": "A"
      }],
      "title": "All stations · data delivery",
      "type": "table"
    },
