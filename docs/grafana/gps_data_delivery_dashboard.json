        "rawSql": "SELECT\n  ts AS \"Time\",\n  sid AS \"Station\",\n  session_type AS \"Session\",\n  outcome AS \"Outcome\",\n  duration_seconds AS \"Dur (s)\",\n  bytes_downloaded AS \"Bytes\",\n  ROUND((avg_speed_bps / 1024.0)::numeric, 1) AS \"KB/s\",\n  attempt AS \"Att\",\n  message AS \"Message\"\nFROM download_log\nWHERE ts BETWEEN $__timeFrom() AND $__timeTo()\n  AND (${station:singlequote} = 'all' OR sid = ${station:singlequote})\nORDER BY ts DESC\nLIMIT 200",
