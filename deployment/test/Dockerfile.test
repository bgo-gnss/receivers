# Test Dockerfile for GPS Receivers Scheduler Installation
# Simulates a fresh Ubuntu production server

FROM ubuntu:24.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install minimal requirements that would exist on a production server
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    git \
    sudo \
    systemctl \
    && rm -rf /var/lib/apt/lists/*

# Set up a test directory structure
WORKDIR /opt

# The receivers repository will be mounted here during docker run
# This simulates: cd /opt && git clone https://github.com/bennigo/receivers.git

CMD ["/bin/bash"]
