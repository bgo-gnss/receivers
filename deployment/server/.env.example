# Grafana server deployment — environment overrides for docker-compose.yml
#
# Copy this file to `.env` in THIS directory and set real values:
#   cp .env.example .env && $EDITOR .env
# `.env` is gitignored (per-host secret) and is auto-loaded by
# `docker compose` from the compose file's directory.
#
# Without a `.env`, the compose defaults apply — notably the admin password
# falls back to "admin", which is unsafe with anonymous Viewer access enabled.

# --- Grafana admin login (user: admin) -------------------------------------
# REQUIRED in production. Sets GF_SECURITY_ADMIN_PASSWORD.
GF_ADMIN_PASSWORD=change-me

# --- PostgreSQL datasource (gps_health) ------------------------------------
# On rek-d01 the datasource authenticates via pg_hba trust for the local
# `gpsops` role, so GF_DATASOURCE_PASSWORD may be left EMPTY there. Set both
# only if the host's pg_hba requires a password for the datasource role.
GF_DATASOURCE_USER=gpsops
GF_DATASOURCE_PASSWORD=
